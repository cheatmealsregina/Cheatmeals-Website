# Supabase — copy this file to .env.local and fill in your project's values.
# Find both under: Supabase dashboard -> Project Settings -> API.
#
# VITE_SUPABASE_URL       — your project's API URL (https://<project-ref>.supabase.co)
# VITE_SUPABASE_ANON_KEY  — the anon/public key. Safe to ship to browsers;
#                           Row Level Security governs what it can access.
#
# NEVER put the service_role key in this app — it bypasses RLS and must
# only live in trusted server environments.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
